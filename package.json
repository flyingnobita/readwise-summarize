{
  "name": "readwise-summarize",
  "version": "1.0.3",
  "description": "CLI tools for fetching Readwise Reader content and generating AI summaries",
  "type": "module",
  "bin": {
    "reader-fetch": "./dist/reader-fetch.js",
    "summarize": "./dist/summarize.js",
    "openrouter-rank-free": "./dist/openrouter-rank-free.js"
  },
  "files": [
    "dist",
    "config.toml",
    "config_prompt.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "release": "tsx src/release.ts",
    "set-github-secrets": "bash scripts/set-github-secrets.sh",
    "reader-fetch": "tsx src/reader-fetch.ts",
    "openrouter-rank-free": "tsx src/openrouter-rank-free.ts",
    "summarize": "tsx src/summarize.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --reporter=verbose --config vitest.integration.config.ts"
  },
  "keywords": [
    "readwise",
    "openrouter",
    "cli",
    "summarization"
  ],
  "author": "flyingnobita",
  "license": "MIT",
  "homepage": "https://github.com/flyingnobita/readwise-summarize#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flyingnobita/readwise-summarize.git"
  },
  "bugs": {
    "url": "https://github.com/flyingnobita/readwise-summarize/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "chrono-node": "^2.9.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "approvedBuilds": [
      "esbuild"
    ]
  },
  "vitest": {}
}
